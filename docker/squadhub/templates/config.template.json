{
  "env": {
    "CONVEX_URL": "${CONVEX_URL}"
  },
  "auth": {
    "profiles": {
      "anthropic:default": {
        "provider": "anthropic",
        "mode": "token"
      }
    }
  },
  "agents": {
    "defaults": {
      "workspace": "/data/workspace",
      "compaction": {
        "mode": "safeguard"
      },
      "maxConcurrent": 4,
      "subagents": {
        "maxConcurrent": 8
      }
    },
    "list": [
      {
        "id": "main",
        "default": true,
        "name": "Clawe",
        "workspace": "/data/workspace",
        "identity": {
          "name": "Clawe",
          "emoji": "🦞"
        }
      },
      {
        "id": "chiron",
        "name": "Chiron",
        "workspace": "/data/workspace-chiron",
        "model": "anthropic/claude-sonnet-4-20250514",
        "identity": {
          "name": "Chiron",
          "emoji": "🦾"
        }
      },
      {
        "id": "sage",
        "name": "Sage",
        "workspace": "/data/workspace-sage",
        "model": "anthropic/claude-sonnet-4-20250514",
        "identity": {
          "name": "Sage",
          "emoji": "🧠"
        }
      },
      {
        "id": "forge",
        "name": "Forge",
        "workspace": "/data/workspace-forge",
        "model": "anthropic/claude-sonnet-4-20250514",
        "identity": {
          "name": "Forge",
          "emoji": "🔧"
        }
      },
      {
        "id": "pixel",
        "name": "Pixel",
        "workspace": "/data/workspace-pixel",
        "model": "anthropic/claude-sonnet-4-20250514",
        "identity": {
          "name": "Pixel",
          "emoji": "📐"
        }
      },
      {
        "id": "echo",
        "name": "Echo",
        "workspace": "/data/workspace-echo",
        "model": "anthropic/claude-sonnet-4-20250514",
        "identity": {
          "name": "Echo",
          "emoji": "📢"
        }
      },
      {
        "id": "vox",
        "name": "Vox",
        "workspace": "/data/workspace-vox",
        "model": "anthropic/claude-sonnet-4-20250514",
        "identity": {
          "name": "Vox",
          "emoji": "🎙️"
        }
      },
      {
        "id": "scout",
        "name": "Scout",
        "workspace": "/data/workspace-scout",
        "model": "anthropic/claude-sonnet-4-20250514",
        "identity": {
          "name": "Scout",
          "emoji": "🔭"
        }
      }
    ]
  },
  "plugins": {
    "load": {
      "paths": ["/opt/clawe/extensions/clawe"]
    }
  },
  "tools": {
    "agentToAgent": {
      "enabled": true,
      "allow": [
        "main",
        "chiron",
        "sage",
        "forge",
        "pixel",
        "echo",
        "vox",
        "scout"
      ]
    }
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto"
  },
  "hooks": {
    "internal": {
      "enabled": true,
      "entries": {
        "session-memory": {
          "enabled": true
        }
      }
    }
  },
  "gateway": {
    "port": ${OPENCLAW_PORT},
    "mode": "local",
    "bind": "lan",
    "auth": {
      "mode": "token",
      "token": "${OPENCLAW_TOKEN}"
    },
    "tools": {
      "allow": ["gateway"]
    },
    "http": {
      "endpoints": {
        "chatCompletions": {
          "enabled": true
        }
      }
    }
  }
}
